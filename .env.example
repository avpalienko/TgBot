# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenAI API Key (get from platform.openai.com)
OPENAI_API_KEY=sk-your-api-key-here

# AI Model (optional, default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Custom API base URL (optional, for compatible providers)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Max automatic retries for transient API errors (optional, default: 3)
# Retries connection errors, 408, 409, 429, and >=500 with exponential backoff
# OPENAI_MAX_RETRIES=3

# Allowed Telegram user IDs, comma-separated (optional)
# Leave empty to allow everyone
# Get your ID from @userinfobot
ALLOWED_USERS=

# Max messages in conversation history (optional, default: 20)
MAX_HISTORY=20

# Idle session lifetime (optional, default: 24h)
# Uses Go duration format: 24h, 1h30m, 720h
# SESSION_TTL=24h

# Max concurrent message handlers (optional, default: 20)
MAX_CONCURRENCY=20

# Per-request timeout (optional, default: 60s)
# Uses Go duration format: 60s, 2m, 2m30s
# REQUEST_TIMEOUT=60s

# Max prompt length in characters (optional, default: 4000)
# Messages exceeding this limit are rejected
# MAX_PROMPT_LENGTH=4000

# Logging level (optional, default: info)
# Options: debug, info, warn, error
LOG_LEVEL=info

# Logging format (optional, default: text)
# Options: text, json
LOG_FORMAT=text
